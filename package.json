{
  "name": "[회사용]-뉴스기자-작성봇",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --mode client && node -e \"require('fs').writeFileSync('dist/_routes.json', JSON.stringify({version:1,include:['/api/*'],exclude:[]}))\"",
    "build:server": "vite build",
    "build:client": "vite build --mode client",
    "preview": "wrangler pages dev dist --ip 0.0.0.0 --port 3000"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "@hono/vite-cloudflare-pages": "^0.4.3",
    "hono": "^4.12.7",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wrangler": "^4.72.0"
  }
}
